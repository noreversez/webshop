# Environment Variables Template
# Copy this file to .env.local and fill in your values

# === DATABASE ===
DATABASE_URL="postgresql://username:password@localhost:5432/fashion_store"

# === NEXTAUTH ===
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000"

# === LINE LOGIN ===
# Get from: https://developers.line.biz/
LINE_CLIENT_ID="your-line-channel-id"
LINE_CLIENT_SECRET="your-line-channel-secret"
NEXT_PUBLIC_LINE_LIFF_ID="your-liff-id"

# === GOOGLE DRIVE ===
# Get from: https://console.cloud.google.com/
GOOGLE_CLIENT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour-private-key\n-----END RSA PRIVATE KEY-----"
GOOGLE_DRIVE_FOLDER_ID="your-google-drive-folder-id-for-product-images"
GOOGLE_DRIVE_SLIP_FOLDER_ID="your-google-drive-folder-id-for-slips"

# === POINTS CONFIG ===
# Points earned per 100 baht spent (e.g., 1 = 1 point per 100 baht)
POINTS_PER_100_BAHT="1"
